# EchoSub 环境变量配置

# Python 后端端口
PORT=8765

# ASR 模型选择: large-v3-turbo / medium / small / base
ASR_MODEL=large-v3-turbo

# 翻译模型 (Ollama): qwen2.5:7b / qwen2.5:1.5b / qwen2.5:14b
TRANSLATION_MODEL=qwen2.5:7b

# Ollama API 地址
OLLAMA_BASE_URL=http://localhost:11434

# 音频采样率 (请勿修改)
SAMPLE_RATE=16000

# 音频分片大小 (毫秒)
CHUNK_DURATION_MS=200
