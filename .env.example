# EchoSub 环境变量配置
# 复制此文件为 .env 并填入你的配置
# cp .env.example .env

# DeepSeek API Key (必填！)
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-api-key-here

# DeepSeek API 配置
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ASR 模型: tiny / base / small(推荐，实时性与准确率最佳平衡) / medium / large-v3-turbo
ASR_MODEL=small

# ASR 测试模式（可选，首次使用建议开启）
# 设为 true 时只进行语音识别，不调用 DeepSeek API 翻译
# 用于验证 ASR 识别效果，确认识别准确后再开启翻译
# ASR_ONLY=true
